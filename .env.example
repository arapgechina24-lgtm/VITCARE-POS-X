# ── Supabase (leave blank to run in offline Demo Mode with seed data) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Safaricom Daraja (M-Pesa). Get sandbox keys at developer.safaricom.co.ke ──
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_ENV=sandbox            # sandbox | production
MPESA_CALLBACK_URL=          # e.g. https://yourapp.vercel.app/api/mpesa/callback

# ── AI Assistant (optional). Anthropic recommended; falls back to rule-based search. ──
ANTHROPIC_API_KEY=

# ── Company / KRA ──
NEXT_PUBLIC_COMPANY_NAME=Vitcare Pharmacy and Medical Centre
NEXT_PUBLIC_COMPANY_TAGLINE=Your Trusted Pharmacy Partner in Naivasha
NEXT_PUBLIC_KRA_PIN=P051234567X

# ── KRA eTIMS (OSCU/VSCU). Leave blank to run in Simulation Mode with demo invoice stamps ──
KRA_ETIMS_BASE_URL=
KRA_ETIMS_CU_SERIAL=
KRA_ETIMS_API_KEY=
KRA_ETIMS_ENV=sandbox         # sandbox | production
